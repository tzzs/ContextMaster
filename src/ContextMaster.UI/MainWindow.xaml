<Window
    x:Class="ContextMaster.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ContextMaster.UI"
    xmlns:controls="using:ContextMaster.UI.Controls"
    xmlns:helpers="using:ContextMaster.UI.Helpers"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏 -->
        <Border
            Grid.Row="0"
            Background="Transparent"
            x:Name="TitleBarBorder">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Margin="8,0">

                    <Border
                        Width="20"
                        Height="20"
                        Background="{StaticResource AccentPrimaryBrush}"
                        CornerRadius="4">
                        <TextBlock
                            Text="📋"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <TextBlock
                        Text="ContextMaster"
                        Style="{StaticResource BodyTextStyle}"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0" />

                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    Text="Windows 右键菜单管理工具"
                    Style="{StaticResource CaptionTextStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border
                Grid.Column="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,1,0"
                Background="{StaticResource SurfaceBrush}">

                <StackPanel Margin="8,0">
                    <NavigationView
                        x:Name="NavView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        CompactPaneLength="48"
                        OpenPaneLength="220"
                        PaneDisplayMode="Left"
                        Background="Transparent"
                        SelectionChanged="NavView_SelectionChanged">

                        <NavigationView.MenuItems>
                            <NavigationViewItem
                                x:Name="MenuItem_Main"
                                Content="菜单管理"
                                Tag="main"
                                Icon="List">
                            </NavigationViewItem>
                            <NavigationViewItem
                                x:Name="MenuItem_History"
                                Content="操作记录"
                                Tag="history"
                                Icon="Clock">
                            </NavigationViewItem>
                            <NavigationViewItem
                                x:Name="MenuItem_Backup"
                                Content="备份管理"
                                Tag="backup"
                                Icon="Save">
                            </NavigationViewItem>
                        </NavigationView.MenuItems>

                        <Frame x:Name="ContentFrame" />

                    </NavigationView>
                </StackPanel>

            </Border>

            <!-- 右侧内容 -->
            <Frame
                x:Name="MainContentFrame"
                Grid.Column="1"
                Background="Transparent" />

        </Grid>

        <!-- 底部状态栏 -->
        <Border
            Grid.Row="2"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Background="{StaticResource SurfaceBrush}"
            Padding="8,4">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="就绪"
                    VerticalAlignment="Center" />

                <Button
                    Grid.Column="1"
                    Content="撤销上一步"
                    Style="{StaticResource TextButtonStyle}"
                    Height="24"
                    Padding="8,0"
                    CornerRadius="{StaticResource RadiusSm}"
                    Click="UndoButton_Click" />

            </Grid>

        </Border>

    </Grid>

</Window>
