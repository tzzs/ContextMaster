<Page
    x:Class="ContextMaster.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ContextMaster.UI.Pages"
    xmlns:controls="using:ContextMaster.UI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundColorBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource Spacing16Thickness}">
        <StackPanel Spacing="{StaticResource Spacing16}">

            <!-- 权限设置 -->
            <Border
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}"
                Padding="{StaticResource Spacing12Thickness}">

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource TitleTextStyle}"
                        Text="权限设置"
                        Margin="0,0,0,12" />

                    <!-- 权限状态 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="当前权限状态"
                            Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 权限状态指示器 -->
                            <Border
                                x:Name="AdminStatusIndicator"
                                Grid.Column="0"
                                Width="12"
                                Height="12"
                                CornerRadius="100"
                                Background="{StaticResource AccentPrimaryBrush}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    x:Name="AdminStatusText"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="正在检查..." />
                                <TextBlock
                                    x:Name="AdminStatusDetail"
                                    Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- 以管理员身份重启 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="以管理员身份运行"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="需要管理员权限才能修改注册表"
                            Margin="0,0,0,8" />
                        <Button
                            x:Name="RestartAsAdminButton"
                            Content="以管理员身份重启"
                            Background="{StaticResource AccentPrimaryBrush}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            Height="32"
                            Padding="12,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            HorizontalAlignment="Left"
                            Click="RestartAsAdminButton_Click" />
                    </StackPanel>
                </StackPanel>

            </Border>

            <!-- 一般设置 -->
            <Border
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}"
                Padding="{StaticResource Spacing12Thickness}">

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource TitleTextStyle}"
                        Text="一般设置"
                        Margin="0,0,0,12" />

                    <!-- 自动备份 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="自动备份"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="还原操作前自动创建备份"
                            Margin="0,0,0,8" />
                        <controls:ContextToggleSwitch IsOn="True" />
                    </StackPanel>

                    <!-- 启动时检查更新 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="启动时检查更新"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="应用程序启动时自动检查更新"
                            Margin="0,0,0,8" />
                        <controls:ContextToggleSwitch IsOn="True" />
                    </StackPanel>
                </StackPanel>

            </Border>

            <!-- 界面设置 -->
            <Border
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}"
                Padding="{StaticResource Spacing12Thickness}">

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource TitleTextStyle}"
                        Text="界面设置"
                        Margin="0,0,0,12" />

                    <!-- 语言 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="语言"
                            Margin="0,0,0,4" />
                        <ComboBox
                            Header="选择语言"
                            PlaceholderText="选择语言"
                            Width="200">
                            <ComboBoxItem Content="简体中文" IsSelected="True" />
                            <ComboBoxItem Content="English" />
                        </ComboBox>
                    </StackPanel>

                    <!-- 主题 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="主题"
                            Margin="0,0,0,4" />
                        <ComboBox
                            Header="选择主题"
                            PlaceholderText="选择主题"
                            Width="200">
                            <ComboBoxItem Content="浅色" IsSelected="True" />
                            <ComboBoxItem Content="深色" />
                            <ComboBoxItem Content="系统" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

            </Border>

            <!-- 高级设置 -->
            <Border
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}"
                Padding="{StaticResource Spacing12Thickness}">

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource TitleTextStyle}"
                        Text="高级设置"
                        Margin="0,0,0,12" />

                    <!-- 危险操作警告 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="危险操作警告"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="执行删除等危险操作前显示确认对话框"
                            Margin="0,0,0,8" />
                        <controls:ContextToggleSwitch IsOn="True" />
                    </StackPanel>

                    <!-- 显示系统条目 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="显示系统条目"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="在列表中显示系统菜单条目"
                            Margin="0,0,0,8" />
                        <controls:ContextToggleSwitch IsOn="True" />
                    </StackPanel>

                    <!-- 清除数据 -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="清除所有数据"
                            Margin="0,0,0,4" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="清除所有操作记录和备份数据（不可恢复）"
                            Margin="0,0,0,8" />
                        <Button
                            Content="清除数据"
                            Background="{StaticResource DangerBackgroundBrush}"
                            Foreground="{StaticResource DangerBrush}"
                            BorderThickness="0"
                            Height="32"
                            Padding="12,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>

            </Border>

            <!-- 关于 -->
            <Border
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}"
                Padding="{StaticResource Spacing12Thickness}">

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource TitleTextStyle}"
                        Text="关于"
                        Margin="0,0,0,12" />

                    <TextBlock
                        Style="{StaticResource BodyTextStyle}"
                        Text="ContextMaster"
                        Margin="0,0,0,4" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="版本 1.0.0"
                        Margin="0,0,0,8" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="Windows 右键菜单管理工具"
                        Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button
                            Content="检查更新"
                            Background="{StaticResource Surface2Brush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Height="32"
                            Padding="12,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            Margin="0,0,8,0" />
                        <Button
                            Content="访问网站"
                            Background="{StaticResource AccentPrimaryBrush}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            Height="32"
                            Padding="12,0"
                            CornerRadius="{StaticResource RadiusSm}" />
                    </StackPanel>
                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>
