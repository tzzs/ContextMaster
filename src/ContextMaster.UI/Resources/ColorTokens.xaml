<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主要强调色 -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#0067C0" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#005A9E" />
    <SolidColorBrush x:Key="AccentBackgroundBrush" Color="#EFF6FC" />

    <!-- 状态颜色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#0F7B0F" />
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#DFF6DD" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C42B1C" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#FDE7E9" />
    <SolidColorBrush x:Key="WarningBrush" Color="#9D5D00" />
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF4CE" />

    <!-- 背景色 -->
    <SolidColorBrush x:Key="BackgroundColorBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#F9F9F9" />

    <!-- 边框色 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Border2Brush" Color="#EBEBEB" />

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#616161" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8A8A8A" />

    <!-- 其他颜色 -->
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BlackBrush" Color="#000000" />
    <SolidColorBrush x:Key="DisabledTrackBrush" Color="#BDBDBD" />

</ResourceDictionary>
