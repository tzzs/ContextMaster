<Page
    x:Class="ContextMaster.UI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ContextMaster.UI.Pages"
    xmlns:controls="using:ContextMaster.UI.Controls"
    xmlns:helpers="using:ContextMaster.UI.Helpers"
    xmlns:enums="using:ContextMaster.Core.Models.Enums"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundColorBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具栏区域 -->
        <Border
            Grid.Row="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="{StaticResource Spacing16Thickness}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 场景标题 -->
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="SceneTitle"
                        Style="{StaticResource TitleTextStyle}"
                        Text="文件"
                        Margin="0,0,8,0" />
                </StackPanel>

                <!-- 搜索框 -->
                <TextBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    PlaceholderText="搜索菜单项..."
                    Height="32"
                    Width="300"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    CornerRadius="{StaticResource RadiusSm}"
                    TextChanged="SearchBox_TextChanged" />

                <!-- 批量操作按钮 -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="16,0,0,0">
                    <Button
                        x:Name="BatchEnableButton"
                        Content="批量启用"
                        Background="{StaticResource SuccessBackgroundBrush}"
                        Foreground="{StaticResource SuccessBrush}"
                        BorderThickness="0"
                        Height="32"
                        Padding="12,0"
                        CornerRadius="{StaticResource RadiusSm}"
                        Click="BatchEnableButton_Click"
                        Margin="0,0,8,0" />
                    <Button
                        x:Name="BatchDisableButton"
                        Content="批量禁用"
                        Background="{StaticResource DangerBackgroundBrush}"
                        Foreground="{StaticResource DangerBrush}"
                        BorderThickness="0"
                        Height="32"
                        Padding="12,0"
                        CornerRadius="{StaticResource RadiusSm}"
                        Click="BatchDisableButton_Click" />
                </StackPanel>
            </Grid>

        </Border>

        <!-- 内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- 主列表 -->
            <ScrollViewer
                Grid.Column="0"
                VerticalScrollBarVisibility="Auto">

                <StackPanel
                    x:Name="ItemsPanel"
                    Padding="{StaticResource Spacing16Thickness}"
                    Spacing="{StaticResource Spacing8}">

                    <!-- 菜单项卡片将在这里动态生成 -->

                </StackPanel>

            </ScrollViewer>

            <!-- 详情面板 -->
            <Border
                Grid.Column="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Background="Transparent">

                <ScrollViewer
                    VerticalScrollBarVisibility="Auto"
                    Padding="{StaticResource Spacing16Thickness}">

                    <controls:DetailPanel
                        x:Name="DetailPanel"
                        Title="条目详情"
                        Margin="0,0,0,80"
                        Visibility="Collapsed"
                        Toggled="DetailPanel_Toggled"
                        EditClicked="DetailPanel_EditClicked"
                        DeleteClicked="DetailPanel_DeleteClicked"
                        CopyPathClicked="DetailPanel_CopyPathClicked"
                        OpenRegEditClicked="DetailPanel_OpenRegEditClicked" />

                </ScrollViewer>

            </Border>
        </Grid>

    </Grid>

</Page>
