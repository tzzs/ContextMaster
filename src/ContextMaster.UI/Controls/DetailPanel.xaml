<UserControl
    x:Class="ContextMaster.UI.Controls.DetailPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ContextMaster.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:ContextMaster.UI.Helpers"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusMd}"
        Padding="{StaticResource Spacing16Thickness}">

        <StackPanel>
            <!-- 标题区域 -->
            <TextBlock
                Style="{StaticResource TitleTextStyle}"
                Text="{x:Bind Title, Mode=OneWay}"
                Margin="0,0,0,8" />

            <!-- 字段列表 -->
            <StackPanel Margin="0,0,0,16">
                <!-- 名称 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="名称:" Width="80" />
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ItemName, Mode=OneWay}" />
                </StackPanel>

                <!-- 状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="状态:" Width="80" />
                    <local:StatusTag TagType="{x:Bind StatusTagType, Mode=OneWay}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- 类型 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="类型:" Width="80" />
                    <local:StatusTag TagType="{x:Bind TypeTagType, Mode=OneWay}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- 来源 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="来源:" Width="80" />
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind Source, Mode=OneWay}" />
                </StackPanel>

                <!-- 命令 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="命令:" Width="80" />
                    <TextBlock Style="{StaticResource MonoTextStyle}" Text="{x:Bind Command, Mode=OneWay}" />
                </StackPanel>

                <!-- 场景 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="场景:" Width="80" />
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind SceneText, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!-- 注册表路径区块 -->
            <Border
                Background="{StaticResource AccentBackgroundBrush}"
                BorderBrush="{StaticResource AccentPrimaryBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}"
                Padding="{StaticResource Spacing8Thickness}"
                Margin="0,0,0,16">

                <StackPanel>
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="注册表路径" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource MonoTextStyle}" Text="{x:Bind RegistryKey, Mode=OneWay}" />

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button
                            Content="复制路径"
                            Background="{StaticResource AccentPrimaryBrush}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            Height="28"
                            Padding="8,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            Click="CopyPathButton_Click"
                            Margin="0,0,8,0" />

                        <Button
                            Content="打开注册表"
                            Background="{StaticResource Surface2Brush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Height="28"
                            Padding="8,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            Click="OpenRegEditButton_Click" />
                    </StackPanel>
                </StackPanel>

            </Border>

            <!-- 操作按钮区域 -->
            <StackPanel Orientation="Horizontal">
                <Button
                    Content="{x:Bind ToggleButtonText, Mode=OneWay}"
                    Background="{x:Bind ToggleButtonBackground, Mode=OneWay}"
                    Foreground="{x:Bind ToggleButtonForeground, Mode=OneWay}"
                    BorderThickness="0"
                    Height="32"
                    Padding="12,0"
                    CornerRadius="{StaticResource RadiusSm}"
                    Click="ToggleButton_Click"
                    Margin="0,0,8,0" />

                <Button
                    Content="编辑"
                    Background="{StaticResource Surface2Brush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Height="32"
                    Padding="12,0"
                    CornerRadius="{StaticResource RadiusSm}"
                    Click="EditButton_Click"
                    Margin="0,0,8,0" />

                <Button
                    Content="删除"
                    Background="{StaticResource DangerBackgroundBrush}"
                    Foreground="{StaticResource DangerBrush}"
                    BorderThickness="0"
                    Height="32"
                    Padding="12,0"
                    CornerRadius="{StaticResource RadiusSm}"
                    Click="DeleteButton_Click" />
            </StackPanel>
        </StackPanel>

    </Border>

</UserControl>
