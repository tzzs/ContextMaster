<Page
    x:Class="ContextMaster.UI.Pages.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ContextMaster.UI.Pages"
    xmlns:controls="using:ContextMaster.UI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundColorBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具栏区域 -->
        <Border
            Grid.Row="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="{StaticResource Spacing16Thickness}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <TextBlock
                    Grid.Column="0"
                    Style="{StaticResource TitleTextStyle}"
                    Text="备份管理"
                    VerticalAlignment="Center" />

                <!-- 操作按钮 -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Button
                        Content="导入备份"
                        Background="{StaticResource Surface2Brush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        Height="32"
                        Padding="12,0"
                        CornerRadius="{StaticResource RadiusSm}"
                        Margin="0,0,8,0" />
                    <Button
                        Content="创建备份"
                        Background="{StaticResource AccentPrimaryBrush}"
                        Foreground="{StaticResource WhiteBrush}"
                        BorderThickness="0"
                        Height="32"
                        Padding="12,0"
                        CornerRadius="{StaticResource RadiusSm}" />
                </StackPanel>
            </Grid>

        </Border>

        <!-- 警告条 -->
        <Border
            Grid.Row="1"
            Background="{StaticResource WarningBackgroundBrush}"
            BorderBrush="{StaticResource WarningBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,8">

            <Grid>
                <TextBlock
                    Style="{StaticResource CaptionTextStyle}"
                    Text="⚠️ 还原操作将覆盖当前配置，建议先创建一个新备份" />
            </Grid>

        </Border>

        <!-- 备份列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <GridView
                x:Name="BackupGridView"
                Padding="{StaticResource Spacing16Thickness}"
                SelectionMode="Single">

                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="{StaticResource Spacing12Thickness}"
                            Width="280"
                            Margin="0,0,16,16">

                            <StackPanel>
                                <!-- 标题行 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding Name}" />

                                    <controls:StatusTag
                                        Grid.Column="1"
                                        TagType="{Binding Type}"
                                        VerticalAlignment="Center" />
                                </Grid>

                                <!-- 创建时间 -->
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding FormattedCreationTime}"
                                    Margin="0,0,0,8" />

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Content="还原"
                                        Background="{StaticResource AccentBackgroundBrush}"
                                        Foreground="{StaticResource AccentPrimaryBrush}"
                                        BorderThickness="0"
                                        Height="28"
                                        Padding="12,0"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Margin="0,0,8,0" />
                                    <Button
                                        Content="导出"
                                        Background="{StaticResource Surface2Brush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        Height="28"
                                        Padding="12,0"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Margin="0,0,8,0" />
                                    <Button
                                        Content="删除"
                                        Background="{StaticResource DangerBackgroundBrush}"
                                        Foreground="{StaticResource DangerBrush}"
                                        BorderThickness="0"
                                        Height="28"
                                        Padding="12,0"
                                        CornerRadius="{StaticResource RadiusSm}" />
                                </StackPanel>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>
        </ScrollViewer>

    </Grid>

</Page>
