<UserControl
    x:Class="ContextMaster.UI.Controls.ContextToggleSwitch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ContextMaster.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Width="40"
        Height="20"
        Background="{x:Bind TrackBackground, Mode=OneWay}"
        CornerRadius="{StaticResource RadiusFull}"
        PointerPressed="RootGrid_PointerPressed">

        <Ellipse
            x:Name="Thumb"
            Width="14"
            Height="14"
            Fill="{StaticResource WhiteBrush}"
            Margin="3,0,0,0">
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="ThumbTransform" />
            </Ellipse.RenderTransform>
        </Ellipse>

    </Grid>

</UserControl>
