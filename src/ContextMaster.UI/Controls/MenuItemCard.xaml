<UserControl
    x:Class="ContextMaster.UI.Controls.MenuItemCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ContextMaster.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:ContextMaster.UI.Helpers"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusMd}"
        Padding="{StaticResource Spacing12Thickness}">

        <Grid>
            <!-- 布局行定义 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 第一行：选择框 + 图标 + 名称 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 选择框 -->
                <CheckBox
                    x:Name="SelectCheckBox"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Checked="SelectCheckBox_Checked"
                    Unchecked="SelectCheckBox_Unchecked" />

                <!-- 图标 -->
                <Border
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    Background="{StaticResource AccentBackgroundBrush}"
                    CornerRadius="{StaticResource RadiusSm}">
                    <TextBlock
                        Text="📋"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>

                <!-- 名称 -->
                <TextBlock
                    Grid.Column="2"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{x:Bind ItemName, Mode=OneWay}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0" />

                <!-- 类型标签 -->
                <local:StatusTag
                    Grid.Column="3"
                    TagType="{x:Bind TagType, Mode=OneWay}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0" />
            </Grid>

            <!-- 第二行：来源程序 -->
            <TextBlock
                Grid.Row="1"
                Style="{StaticResource CaptionTextStyle}"
                Text="{x:Bind Source, Mode=OneWay}"
                Margin="48,4,0,0" />

            <!-- 第三行：操作按钮 -->
            <Grid Grid.Row="2" Margin="48,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 启用/禁用按钮 -->
                <Button
                    Grid.Column="0"
                    Content="{x:Bind ButtonText, Mode=OneWay}"
                    Background="{x:Bind ButtonBackground, Mode=OneWay}"
                    Foreground="{x:Bind ButtonForeground, Mode=OneWay}"
                    BorderThickness="0"
                    Height="24"
                    Padding="8,0"
                    CornerRadius="{StaticResource RadiusSm}"
                    Click="ToggleButton_Click" />

                <!-- 场景标签 -->
                <TextBlock
                    Grid.Column="2"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="{x:Bind SceneText, Mode=OneWay}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" />

                <!-- 切换开关 -->
                <local:ContextToggleSwitch
                    Grid.Column="3"
                    IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                    Toggled="ToggleSwitch_Toggled"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0" />
            </Grid>
        </Grid>

    </Border>

</UserControl>
