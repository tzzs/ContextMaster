<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 间距值 -->
    <x:Double x:Key="Spacing4">4</x:Double>
    <x:Double x:Key="Spacing8">8</x:Double>
    <x:Double x:Key="Spacing12">12</x:Double>
    <x:Double x:Key="Spacing16">16</x:Double>
    <x:Double x:Key="Spacing20">20</x:Double>
    <x:Double x:Key="Spacing24">24</x:Double>

    <!-- Thickness 资源 -->
    <Thickness x:Key="Spacing4Thickness">4</Thickness>
    <Thickness x:Key="Spacing8Thickness">8</Thickness>
    <Thickness x:Key="Spacing12Thickness">12</Thickness>
    <Thickness x:Key="Spacing16Thickness">16</Thickness>
    <Thickness x:Key="Spacing20Thickness">20</Thickness>

    <!-- 常用组合间距 -->
    <Thickness x:Key="CardPadding">12</Thickness>
    <Thickness x:Key="PagePadding">16</Thickness>
    <Thickness x:Key="ControlPadding">8,4</Thickness>

</ResourceDictionary>
