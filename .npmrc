# 使用国内 npm 镜像（可选，如果网络正常可以用官方）
registry=https://registry.npmmirror.com

# Electron / Forge / Webpack 等工具需要扁平 node_modules
node-linker=hoisted

# 将依赖提升到 node_modules 根目录，避免工具找不到依赖
public-hoist-pattern[]=*

# 自动安装 peerDependencies
auto-install-peers=true

# 允许依赖执行 install/postinstall 脚本（Electron / esbuild / native module 必须）
ignore-scripts=false

# Windows 下更稳定地执行 shell script
shell-emulator=true

# CI 或团队环境锁定依赖
prefer-frozen-lockfile=true

# 网络重试优化（国内环境更稳定）
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
